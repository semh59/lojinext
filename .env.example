# ============================================================
# LojiNext -- Environment Variable Template
# Copy this file to .env and fill in real values.
# NEVER commit .env -- it is git-ignored.
# ============================================================

# -- Core
PROJECT_NAME=LojiNext
ENVIRONMENT=prod
LOG_LEVEL=INFO

# -- Auth
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_char_hex
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_AUDIENCE=lojinext-api
JWT_REFRESH_AUDIENCE=lojinext-refresh
JWT_ISSUER=lojinext-api
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=CHANGE_ME
ADMIN_PASSWORD=CHANGE_ME

# -- Database
DATABASE_URL=postgresql+asyncpg://lojinext_user:CHANGE_ME@db:5432/lojinext_db
POSTGRES_USER=lojinext_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=lojinext_db

# -- Cache / Queue
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# -- Redis auth (required in prod; leave blank for dev)
REDIS_PASSWORD=CHANGE_ME_redis_password
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_EAGER=false

# -- CORS (comma-separated origins; prod: only your domain)
CORS_ORIGINS=https://your-domain.com

# -- Metrics (IPs/CIDRs allowed to scrape /metrics)
METRICS_ALLOWED_IPS=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8

# -- External APIs
# openrouteservice.org -> My Account -> API Keys
OPENROUTESERVICE_API_KEY=CHANGE_ME
# mapbox.com -> Account -> Tokens
MAPBOX_API_KEY=CHANGE_ME
WEATHER_API_KEY=

# -- AI / LLM
# console.groq.com
GROQ_API_KEY=CHANGE_ME
GROQ_MODEL_NAME=llama-3.1-70b-versatile
AI_TEMPERATURE=0.2
# huggingface.co -> Settings -> Access Tokens
HF_TOKEN=CHANGE_ME
AI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
AI_EMBEDDING_DIM=384

# -- ML Tuning
VEHICLE_AGE_DEGRADATION_RATE=0.015
MAX_AGE_DEGRADATION=0.15
ANOMALY_Z_THRESHOLD=2.5

# -- Observability
# sentry.io -> Settings -> Projects -> Client Keys (DSN)
SENTRY_DSN=
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# -- Production server (recommended: 2 * CPU_count + 1)
UVICORN_WORKERS=4


# -- Production deployment
# Docker image tag (required in prod; e.g. v1.2.3 - no :latest)
IMAGE_TAG=
# Backup retention in days
BACKUP_RETENTION_DAYS=30
# -- Email / SMTP (şifre sıfırlama e-postası için zorunlu)
# Gmail: SMTP_HOST=smtp.gmail.com PORT=587 (App Password kullan)
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_USERNAME=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=LojiNext
SMTP_USE_TLS=true

# -- Off-site backup (opsiyonel: S3/R2/Backblaze B2)
BACKUP_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=


# -- Grafana
# Password for Grafana admin user (http://localhost:3000)
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# -- Telegram Bots
# Ops bot: system alerts and service management
# Create via BotFather: /newbot
TELEGRAM_OPS_BOT_TOKEN=
# Chat ID of the ops monitoring group/channel
TELEGRAM_OPS_CHAT_ID=
# URL ops_bot webhook sunucusuna işaret etmeli.
# Docker Compose içinde: http://telegram-ops-bot:8080
# Yerel geliştirmede (bot ayrı çalışıyorsa): http://localhost:8080
TELEGRAM_OPS_BOT_URL=http://telegram-ops-bot:8080

# Driver bot: driver workflow (photo upload, PDF download)
TELEGRAM_DRIVER_BOT_TOKEN=

# Internal API secret -- shared between backend and telegram bot containers
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=CHANGE_ME_internal_secret


# ============================================================
# Web Push (VAPID self-hosted) — RV2.PWA
# Üretim: python -m py_vapid generate (veya py-vapid Python lib)
# VAPID_SUBJECT: gerçek bir mailto: adresi olmalı (browser vendor compliance)
# PUSH_NOTIFICATION_ENABLED=True → /push endpoint'leri aktive olur
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_NOTIFICATION_ENABLED=False


# ============================================================
# 3rd Party Provider Entegrasyonu (read-only)
# Adapter stub'lar hazır — gerçek API bağlantısı için bu deĞrler doldurulmalı.
# ============================================================

# AVL (Araç takip)
AVL_PROVIDER=
AVL_BASE_URL=
AVL_API_KEY=
AVL_ACCOUNT_ID=
AVL_POLL_INTERVAL_SECONDS=900

# Akaryakıt Kart
FUEL_PROVIDER=
FUEL_BASE_URL=
FUEL_API_KEY=
FUEL_ACCOUNT_ID=
FUEL_POLL_INTERVAL_SECONDS=3600


# ============================================================
# Yakıt tahmin motoru (Faz 4-5 + segment-tractive) — prod tuning
# Pilot: USE_SEFER_FUEL_ESTIMATOR=true (sefer kaydında tahmin üretilir).
# USE_SEGMENT_TRACTIVE_MODEL: fiziksel-doğru per-segment motor (validasyon
# sonrası true). PHYSICS_* sabitleri 10 referans rotaya kalibre — değiştirmeden
# önce scripts/calibrate_physics.py ile doğrula.
# ============================================================
USE_SEFER_FUEL_ESTIMATOR=False
USE_SEGMENT_TRACTIVE_MODEL=False
PHYSICS_ENGINE_BSFC=0.42
PHYSICS_DRIVELINE_EFF=0.95
PHYSICS_PARASITIC_KW=4.0
PHYSICS_DRAG_CDA_M2=6.80
PHYSICS_GRADE_CLAMP_PCT=9.0
# Çevresel faktör fiziksel cap'leri (Faz 7)
WEATHER_WIND_FACTOR_MAX=1.10
SEASONAL_FACTOR_MAX=1.03

# ============================================================
# Operasyonel
# ============================================================
# Async/asyncpg per-statement timeout (saniye); 0 = kapalı (DoS koruması, ARCH-016)
DB_COMMAND_TIMEOUT_S=60
# Kullanım analitiği page_views saklama süresi (gün); gece task'i eskiyi siler
ANALYTICS_RETENTION_DAYS=90
# Anomali kümeleri için Groq LLM insight metni (kapalıyken liste yine döner)
ANOMALY_CLUSTER_LLM_ENABLED=False
# Telegram OPS bot webhook (hata + pilot feedback bildirimi)
TELEGRAM_OPS_BOT_URL=http://telegram-ops-bot:8080
