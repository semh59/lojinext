[importlinter]
root_packages =
    app
    v2

[importlinter:contract:report-only]
name = Modular monolith boundary (report-only, FAZ0)
type = independence
modules =
    app.core.services
    app.services

[importlinter:contract:module-cross-domain-infra-independence]
name = 15 modulun domain/infrastructure katmanlari birbirinden bagimsiz (yalniz public/events)
type = independence
modules =
    v2.modules.location.domain
    v2.modules.location.infrastructure
