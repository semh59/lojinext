[importlinter]
root_packages =
    app
    v2

[importlinter:contract:report-only]
name = Modular monolith boundary (report-only, FAZ0)
type = independence
modules =
    app.core.services
    app.services

[importlinter:contract:module-cross-domain-infra-independence]
name = 12 modulun domain/infrastructure katmanlari birbirinden bagimsiz (yalniz public/events)
type = independence
modules =
    v2.modules.location.domain
    v2.modules.location.infrastructure
    v2.modules.route_simulation.domain
    v2.modules.route_simulation.infrastructure
    v2.modules.notification.domain
    v2.modules.notification.infrastructure
    v2.modules.fleet.domain
    v2.modules.fleet.infrastructure
    v2.modules.fuel.domain
    v2.modules.fuel.infrastructure
    v2.modules.driver.domain
    v2.modules.driver.infrastructure
    v2.modules.auth_rbac.domain
    v2.modules.auth_rbac.infrastructure
    v2.modules.anomaly.domain
    v2.modules.anomaly.infrastructure
    v2.modules.import_excel.domain
    v2.modules.import_excel.infrastructure
    v2.modules.reports.domain
    v2.modules.reports.infrastructure
    v2.modules.analytics_executive.domain
    v2.modules.analytics_executive.infrastructure
    v2.modules.ai_assistant.domain
    v2.modules.ai_assistant.infrastructure
    v2.modules.prediction_ml.domain
    v2.modules.prediction_ml.infrastructure
    v2.modules.trip.domain
    v2.modules.trip.infrastructure
    v2.modules.admin_platform.domain
    v2.modules.admin_platform.infrastructure
ignore_imports =
    app.core.container -> v2.modules.ai_assistant.application.orchestrate_ai_response
    app.core.container -> v2.modules.admin_platform.application.health_service
    app.core.container -> v2.modules.trip.application.trip_service
    app.core.container -> app.core.services.weather_service
    app.core.container -> v2.modules.trip.infrastructure.repository
    app.core.container -> app.infrastructure.events.event_bus
    app.core.container -> app.services.external_service
    app.core.container -> v2.modules.prediction_ml.application.prediction_service
    app.core.container -> v2.modules.ai_assistant.application.knowledge_base
