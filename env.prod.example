# =============================================================================
# LojiNext — Production Environment Template
# Kullanım: cp env.prod.example .env  (sunucuda)
#
# SECRET_KEY uretmek icin: openssl rand -hex 32
# Tum <...> alanlari doldurun. Bos birakilan zorunlu alanlar uygulamayi
# baslatmaz (config.py validator'lari devreye girer).
# =============================================================================

# ---------------------------------------------------------------------------
# Uygulama
# ---------------------------------------------------------------------------
ENVIRONMENT=prod
SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SUPER_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ---------------------------------------------------------------------------
# Veritabani
# ---------------------------------------------------------------------------
POSTGRES_USER=lojinext_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=lojinext_db
DATABASE_URL=postgresql+asyncpg://lojinext_user:REPLACE_WITH_STRONG_PASSWORD@db:5432/lojinext_db
DB_HOST=db
DB_PORT=5432
ALEMBIC_READY=true

# ---------------------------------------------------------------------------
# Redis (sifreli)
# ---------------------------------------------------------------------------
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://:REPLACE_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:REPLACE_REDIS_PASSWORD@redis:6379/1

# ---------------------------------------------------------------------------
# AI / Dis API'ler (prod'da zorunlu -- config.py validator'lari)
# ---------------------------------------------------------------------------
GROQ_API_KEY=gsk_REPLACE_ME
HF_TOKEN=hf_REPLACE_ME
OPENROUTESERVICE_API_KEY=REPLACE_ME
# MAPBOX_API_KEY=REPLACE_ME
# ROUTING_PROVIDER_STRATEGY=hybrid

# ---------------------------------------------------------------------------
# CORS -- sunucu IP'si veya domain (wildcard yasak -- config.py validator)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://REPLACE_WITH_SERVER_IP

# ---------------------------------------------------------------------------
# Performans
# ---------------------------------------------------------------------------
UVICORN_WORKERS=4

# ---------------------------------------------------------------------------
# Izleme
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SENTRY_DSN=https://KEY@ORG.ingest.sentry.io/PROJECT
ENABLE_PROMETHEUS_METRICS=true

# ---------------------------------------------------------------------------
# GHCR -- deploy.sh icin
# ---------------------------------------------------------------------------
GHCR_OWNER=REPLACE_WITH_GITHUB_USERNAME
IMAGE_TAG=latest


# ============================================================
# Web Push (VAPID self-hosted) — RV2.PWA
# Üretim: python -m py_vapid generate (veya py-vapid Python lib)
# VAPID_SUBJECT: gerçek bir mailto: adresi olmalı (browser vendor compliance)
# PUSH_NOTIFICATION_ENABLED=True → /push endpoint'leri aktive olur
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_NOTIFICATION_ENABLED=False


# ============================================================
# 3rd Party Provider Entegrasyonu (read-only)
# Adapter stub'lar hazır — gerçek API bağlantısı için bu deĞrler doldurulmalı.
# ============================================================

# AVL (Araç takip)
AVL_PROVIDER=
AVL_BASE_URL=
AVL_API_KEY=
AVL_ACCOUNT_ID=
AVL_POLL_INTERVAL_SECONDS=900

# Akaryakıt Kart
FUEL_PROVIDER=
FUEL_BASE_URL=
FUEL_API_KEY=
FUEL_ACCOUNT_ID=
FUEL_POLL_INTERVAL_SECONDS=3600
