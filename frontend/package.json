{
  "name": "lojinext-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "codegen:dump": "node scripts/dump-openapi.mjs",
    "codegen": "orval",
    "codegen:all": "npm run codegen:dump && npm run codegen",
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:inventory": "playwright test --config playwright.inventory.config.ts",
    "test:e2e:gap": "node e2e/scripts/gap-report.mjs",
    "test:e2e:coverage-check": "npm run test:e2e:inventory && npm run test:e2e:gap"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-toggle": "^1.1.10",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.19",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.29.2",
    "i18next": "^26.0.3",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.309.0",
    "react": "^18.2.0",
    "react-countup": "^6.5.3",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^6.21.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/node": "^25.1.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/parser": "^8.28.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.16",
    "dotenv": "^16.6.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.0.0",
    "jsdom": "^23.0.0",
    "orval": "^8.18.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^1.0.0",
    "workbox-window": "^7.4.1"
  }
}
