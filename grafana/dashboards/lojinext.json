          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes{job=\"redis_exporter\"}",
          "legendFormat": "max memory",
          "refId": "B"
        }
      ],
      "title": "Redis Memory",
      "type": "timeseries"
    },
    {
