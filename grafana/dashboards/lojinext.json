      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "id": 11,
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total{job=\"redis_exporter\"}[1m])",
          "legendFormat": "commands/s",
          "refId": "A"
