          "expr": "rate(telegram_belge_ocr_total{sonuc=\"islendi\"}[1h]) / (rate(telegram_belge_ocr_total{sonuc=\"islendi\"}[1h]) + rate(telegram_belge_ocr_total{sonuc=\"hata\"}[1h]) + 0.0001) * 100",
